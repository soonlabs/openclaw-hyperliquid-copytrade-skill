# Required (minimum for first run)
# Fill these before start.
TARGET_WALLETS=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
HL_WALLET_PRIVATE_KEY=

# Optional (with safe defaults)
MODE=dry-run
MAX_RISK_PER_TRADE_PCT=10
MAX_TOTAL_EXPOSURE_PCT=60
SCORE_THRESHOLD=70
POLL_SECONDS=5
STATE_FILE=./skills/openclaw-hyperliquid-copytrade/state.json
CAPITAL_USD=1000
STATS_LOOKBACK_HOURS=168
MAX_EVENTS_PER_CYCLE=20
KILL_SWITCH=false
LIVE_EXECUTOR_URL=
LIVE_EXECUTOR_BEARER=
RUNTIME_STATUS_FILE=./skills/openclaw-hyperliquid-copytrade/runtime-status.json
STATUS_WEB_URL=http://127.0.0.1:8899
REQUIRE_INITIAL_DECISION=true
TG_OFFSET_FILE=./skills/openclaw-hyperliquid-copytrade/tg-offset.json
WALLET_ANALYTICS_FILE=./skills/openclaw-hyperliquid-copytrade/wallet-analytics.json
TG_LANG=auto
EVENT_GRANULARITY=order
DECISION_DEDUP_WINDOW_SECONDS=0

# Real Hyperliquid executor (optional)
HL_REAL_EXECUTION=false
HL_API_URL=https://api.hyperliquid.xyz
HL_MARKET_SLIPPAGE=0.05
AUTO_TP_PCT=6
AUTO_SL_PCT=3
TRAILING_TP_ENABLE=false
TRAILING_TP_CALLBACK_PCT=1
